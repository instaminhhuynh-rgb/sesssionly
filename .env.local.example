# Copy to .env.local and fill in when you wire up Phase 3+.
# The prototype runs entirely on mock data and needs none of these yet.

# --- Supabase (Phase 3: auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Phase 5: payments + deposits) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI (server-side only) ---
# Used by the No-Show / Session Score agent (lib/agents/no-show). Without it,
# the agent falls back to a deterministic heuristic and the app still works.
ANTHROPIC_API_KEY=
# Optional: override the scoring model (default claude-sonnet-4-6; use Haiku for cost).
SESSIONLY_SCORING_MODEL=

# --- Email / SMS (Phase 5: reminders + confirmations) ---
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
